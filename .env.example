# =============================================================
# TrustEdge — Single .env (repo root) — ONE file for everything
# =============================================================
# Copy to .env and fill in real values. Never commit .env to git.
#
# This file is the ONLY .env needed:
#   • Docker Compose reads it for ${VAR} substitution in docker-compose.yml
#   • All backend services load it via env_file
#   • Frontend containers use only the vars set in docker-compose.yml environment:
#
# DO NOT create backend/.env — it is no longer used.
# =============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=trustedge
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=trustedge

# ─── TimescaleDB ──────────────────────────────────────────────
TIMESCALE_USER=trustedge
TIMESCALE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
TIMESCALE_DB=marketdata

# ─── Connection URLs (must match passwords above) ─────────────
DATABASE_URL=postgresql+asyncpg://trustedge:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/trustedge
TIMESCALE_URL=postgresql+asyncpg://trustedge:CHANGE_THIS_STRONG_PASSWORD@timescaledb:5432/marketdata
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── JWT Secrets — generate with: openssl rand -hex 32 ────────
JWT_SECRET=CHANGE_THIS_RANDOM_64_CHAR_STRING
USER_JWT_SECRET=CHANGE_THIS_RANDOM_64_CHAR_STRING
ADMIN_JWT_SECRET=CHANGE_THIS_OTHER_RANDOM_64_CHAR_STRING
# Access JWT lifetime (minutes). Refresh cookie is separate (JWT_REFRESH_EXPIRY_DAYS).
# Legacy env name JWT_EXPIRY_MINUTES is still accepted as an alias.
JWT_ACCESS_EXPIRY_MINUTES=45
JWT_REFRESH_EXPIRY_DAYS=7
# true = access + refresh cookies are browser-session only (close browser → log in again).
# false = persistent cookies (access ~JWT_ACCESS_EXPIRY_MINUTES, refresh JWT_REFRESH_EXPIRY_DAYS).
JWT_REFRESH_SESSION_COOKIE=true
# HttpOnly cookie flags (trader web). Leave COOKIE_SECURE unset to auto-detect HTTPS.
COOKIE_SAMESITE=strict
# COOKIE_SECURE=true
# Set false only for local HTTP if browsers reject Secure cookies.
# JWT_INCLUDE_LEGACY_JSON_TOKEN=false

# ─── Environment & CORS ───────────────────────────────────────
ENVIRONMENT=production
# Both trader + admin domains required here
CORS_ORIGINS=https://trustedge.today,https://admin.trustedge.today
# Trader site origin for password-reset email links (no trailing slash)
TRADER_APP_URL=https://trustedge.today

# ─── Outbound email (password reset) ───────────────────────────
# If SMTP_HOST is empty, reset emails are NOT sent (production logs a warning; dev logs the link).
# Gmail: enable 2FA, create an App Password, use smtp.gmail.com:587, your full address as SMTP_USER.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=TrustEdge <you@gmail.com>
# SMTP_USE_TLS=true

# ─── Admin service ────────────────────────────────────────────
ADMIN_REDIS_URL=redis://redis:6379/1

# ─── Risk engine ──────────────────────────────────────────────
MARGIN_CALL_LEVEL=80.0
STOP_OUT_LEVEL=50.0
MAX_OPEN_TRADES=200
DEFAULT_LEVERAGE=100

# KYC file storage (gateway). Use an absolute path on a writable volume in production, e.g. /app/data/kyc
# KYC_UPLOAD_ROOT=/app/data/kyc
# Manual deposit screenshots + user payout QR images — mount the same path on gateway AND admin services.
# WALLET_UPLOAD_ROOT=/app/data/wallet

# ─── CORS (locked down for production) ─────────────────
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With,Accept

# ─── Sentry (error monitoring) ────────────────────────
# Leave empty to disable. Get a DSN from https://sentry.io
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_TRADING=120/minute

# ─── Request Size Limit (bytes, default 10 MB) ────────
MAX_REQUEST_SIZE=10485760

# ─── Market Data (Infoway.io) ─────────────────────────
# Used by Docker service `market-data` (publishes ticks to Redis). Gateway/trader read Redis.
# Leave empty or use a real key from Infoway dashboard; placeholders → simulated feed only.
INFOWAY_API_KEY=your-infoway-api-key-here
INFOWAY_API_URL=https://api.infoway.io

# ─── Default admin UI login (init-db.sql + alembic revision 0002) ───
# Email: admin@trustedge.com  |  Password: TrustEdgeAdmin2025!
# Change password after first login; run: docker compose --profile migrate run --rm migrate
