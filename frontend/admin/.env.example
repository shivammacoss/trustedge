# =============================================================
# TrustEdge Admin Frontend — .env.example
# Copy to .env.local for local development
# =============================================================
# Production: host the admin app on https://admin.trustedge.today (or path-based).
# Same-origin /admin-api proxy targets the admin API container server-side.
# =============================================================

# ─── Server-side only (NOT exposed to browser) ─────────────────
# Where Next.js proxies /admin-api/* (Docker default set in docker-compose.yml).
# ADMIN_API_PROXY_TARGET=http://127.0.0.1:8001

# Rewrites /api/* on admin app to gateway (Docker default set in docker-compose.yml).
# GATEWAY_INTERNAL_URL=http://127.0.0.1:8000

# ─── NEXT_PUBLIC_* — CAUTION: baked into JS bundle at build time ─
# On HTTPS sites, NEVER set these to http:// or ws:// — browsers block mixed content.
# Leave UNSET in production: the app auto-detects protocol.
#
# Only set for local dev (HTTP):
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
# NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8001
